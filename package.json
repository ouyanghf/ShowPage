{
  "name": "showpage",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --exclude 'src/ui/**' --exclude 'storage/**' --exclude 'dist/**' src/server/index.ts",
    "build": "rm -rf dist && vue-tsc --project src/ui/tsconfig.json --noEmit && vite build && tsc --project tsconfig.server.json",
    "start": "NODE_ENV=production node dist/index.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.0.9",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@vitejs/plugin-vue": "^5.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vue-tsc": "^2.1.0"
  }
}
